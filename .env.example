# Network selection: devnet | mainnet
TXLINE_NETWORK=devnet
# API bases. Devnet defaults to https://txline-dev.txodds.com when unset.
# The mainnet base URL is required for mainnet (confirm from TxLINE docs or Discord).
# TXLINE_MAINNET_API_BASE=
# RPC overrides (optional)
# SOLANA_DEVNET_RPC=
# SOLANA_MAINNET_RPC=
# Wallet used for subscribe and activation signing
# TXLINE_KEYPAIR_PATH=keypairs/feed-devnet.json
# Filled by `bootstrap` (do not commit; .env is gitignored)
# TXLINE_JWT_DEVNET=
# TXLINE_API_TOKEN_DEVNET=
# TXLINE_JWT_MAINNET=
# TXLINE_API_TOKEN_MAINNET=
